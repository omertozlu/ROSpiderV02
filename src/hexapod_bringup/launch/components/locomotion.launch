import os
from ament_index_python.packages import get_package_share_directory
from launch import LaunchDescription
from launch_ros.actions import Node
from launch.substitutions import Command

def generate_launch_description():
    # 1. hexapod_description paket yolunu al
    description_pkg = get_package_share_directory('hexapod_description')
    
    # 2. Xacro dosyasını işle ve robot_description parametresini oluştur
    # Daha önce hazırladığımız xacro dosyasını kullanıyoruz
    xacro_file = os.path.join(description_pkg, 'urdf', 'hexapod_model.xacro')
    robot_description_content = Command(['xacro ', xacro_file])

    # 3. Robot State Publisher Düğümü
    # ROS 1'deki 'state_publisher' artık 'robot_state_publisher' oldu
    rsp_node = Node(
        package='robot_state_publisher',
        executable='robot_state_publisher',
        name='robot_state_publisher',
        output='screen',
        parameters=[{
            'robot_description': robot_description_content,
            'use_sim_time': True # Gazebo kullanıyorsan True kalsın
        }]
    )

    # 4. Hexapod Controller (Ana Yürüyüş Motoru)
    # Not: Bu paket Jazzy için derlenmiş olmalıdır
    controller_node = Node(
        package='hexapod_controller',
        executable='hexapod_controller',
        name='Hexapod_Controller',
        output='screen',
        parameters=[{'use_sim_time': True}]
    )

    return LaunchDescription([
        rsp_node,
        controller_node
    ])