<?xml version="1.0" encoding="UTF-8" ?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="Golem">

<link name="base_footprint"/>

<joint name="base_joint" type="fixed">
    <parent link="base_footprint"/><child link="base_link"/>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
</joint>

<link name="base_link">
    <visual><geometry><mesh filename="file:///root/colcon_ws/src/hexapod_description/meshes/phantomX/body.stl" scale="0.001 0.001 0.001"/></geometry></visual>
    <collision><geometry><box size="0.25 0.15 0.06"/></geometry></collision>
    <inertial><mass value="1.0"/> <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.02"/></inertial>
</link>

<xacro:macro name="leg" params="side position x y angle">
    
    <joint name="coxa_joint_${side}${position}" type="revolute">
        <parent link="base_link"/><child link="coxa_${side}${position}"/><origin xyz="${x} ${y} 0" rpy="0 0 ${angle}"/><axis xyz="0 0 1"/>
        <limit lower="-1.57" upper="1.57" effort="200.0" velocity="2.0"/>
        <dynamics damping="0.5" friction="0.2"/>
    </joint>

    <link name="coxa_${side}${position}">
        <visual><geometry><mesh filename="file:///root/colcon_ws/src/hexapod_description/meshes/phantomX/coxa.stl" scale="0.001 0.001 0.001"/></geometry></visual>
        <collision><geometry><box size="0.05 0.05 0.05"/></geometry></collision>
        <inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
    </link>

    <joint name="femur_joint_${side}${position}" type="revolute">
        <origin xyz="0.029 0 0" rpy="-1.5707 0 0"/><parent link="coxa_${side}${position}"/><child link="femur_${side}${position}"/><axis xyz="0 0 1"/>
        <limit lower="-1.57" upper="1.57" effort="200.0" velocity="2.0"/>
        <dynamics damping="0.5" friction="0.2"/>
    </joint>

    <link name="femur_${side}${position}">
        <visual><geometry><mesh filename="file:///root/colcon_ws/src/hexapod_description/meshes/phantomX/femur.stl" scale="0.001 0.001 0.001"/></geometry></visual>
        <collision><geometry><box size="0.08 0.03 0.03"/></geometry></collision>
        <inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
    </link>

    <joint name="tibia_joint_${side}${position}" type="revolute">
        <origin xyz="0.082 0 0" rpy="0 0 0"/><parent link="femur_${side}${position}"/><child link="tibia_${side}${position}"/><axis xyz="0 0 1"/>
        <limit lower="-1.57" upper="1.57" effort="200.0" velocity="2.0"/>
        <dynamics damping="0.5" friction="0.2"/>
    </joint>

    <link name="tibia_${side}${position}">
        <visual><geometry><mesh filename="file:///root/colcon_ws/src/hexapod_description/meshes/phantomX/tibia.stl" scale="0.001 0.001 0.001"/></geometry></visual>
        <collision><origin xyz="0.05 0 0" rpy="0 0 0"/> <geometry><sphere radius="0.005"/></geometry> </collision>
        <inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
    </link>

    <gazebo reference="tibia_${side}${position}">
        <mu1>2.0</mu1><mu2>2.0</mu2>
        <kp>50000.0</kp> 
        <kd>10.0</kd> 
        <minDepth>0.001</minDepth>
        <maxVel>0.0</maxVel>
    </gazebo>
</xacro:macro>

<xacro:leg side="R" position="F" x="0.124" y="-0.10" angle="-0.785"/>
<xacro:leg side="R" position="M" x="0.0" y="-0.13" angle="-1.57"/>
<xacro:leg side="R" position="R" x="-0.124" y="-0.10" angle="-2.35"/>
<xacro:leg side="L" position="F" x="0.124" y="0.10" angle="0.785"/>
<xacro:leg side="L" position="M" x="0.0" y="0.13" angle="1.57"/>
<xacro:leg side="L" position="R" x="-0.124" y="0.10" angle="2.35"/>

<ros2_control name="GazeboSystem" type="system">
    <hardware><plugin>gazebo_ros2_control/GazeboSystem</plugin></hardware>
    <xacro:macro name="j" params="n"><joint name="${n}"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint></xacro:macro>
    <xacro:j n="coxa_joint_RF"/><xacro:j n="femur_joint_RF"/><xacro:j n="tibia_joint_RF"/>
    <xacro:j n="coxa_joint_LF"/><xacro:j n="femur_joint_LF"/><xacro:j n="tibia_joint_LF"/>
    <xacro:j n="coxa_joint_RM"/><xacro:j n="femur_joint_RM"/><xacro:j n="tibia_joint_RM"/>
    <xacro:j n="coxa_joint_LM"/><xacro:j n="femur_joint_LM"/><xacro:j n="tibia_joint_LM"/>
    <xacro:j n="coxa_joint_RR"/><xacro:j n="femur_joint_RR"/><xacro:j n="tibia_joint_RR"/>
    <xacro:j n="coxa_joint_LR"/><xacro:j n="femur_joint_LR"/><xacro:j n="tibia_joint_LR"/>
</ros2_control>

<gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
        <parameters>/root/colcon_ws/src/hexapod_gazebo/config/phantomx_control.yaml</parameters>
    </plugin>
</gazebo>

<link name="lidar_link">
    <inertial><mass value="0.05"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
    <visual><geometry><cylinder radius="0.05" length="0.04"/></geometry></visual>
</link>

<joint name="lidar_joint" type="fixed">
    <parent link="base_link"/><child link="lidar_link"/><origin xyz="0 0 0.1" rpy="0 0 0"/>
</joint>

<gazebo reference="lidar_link">
    <sensor name="lidar" type="ray">
        <pose>0 0 0 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <ray>
            <scan><horizontal><samples>360</samples><resolution>1</resolution><min_angle>-3.14</min_angle><max_angle>3.14</max_angle></horizontal></scan>
            <range><min>0.3</min><max>12.0</max><resolution>0.01</resolution></range>
        </ray>
        <plugin name="gazebo_ros_laser_controller" filename="libgazebo_ros_ray_sensor.so">
            <ros><remapping>~/out:=scan</remapping></ros>
            <output_type>sensor_msgs/LaserScan</output_type>
            <frame_name>lidar_link</frame_name>
        </plugin>
    </sensor>
</gazebo>

<gazebo>
  <plugin name="gazebo_ros_p3d" filename="libgazebo_ros_p3d.so">
    <ros>
      <namespace>/</namespace>
      <remapping>odom:=odom</remapping>
    </ros>
    <body_name>base_footprint</body_name> <frame_name>world</frame_name>
    <update_rate>50</update_rate>
    <xyz_offset>0 0 0</xyz_offset>
    <rpy_offset>0 0 0</rpy_offset>
    <gaussian_noise>0.01</gaussian_noise>
  </plugin>
</gazebo>

<gazebo>
  <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
    <ros>
      <namespace>/</namespace>
      <remapping>model_states:=model_states</remapping>
    </ros>
    <update_rate>50.0</update_rate>
  </plugin>
</gazebo>

</robot>