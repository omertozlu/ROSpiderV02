<?xml version="1.0" encoding="UTF-8" ?>

<robot xmlns:xacro="http://ros.org/wiki/xacro" name="Golem">



<link name="base_footprint"/>

<joint name="base_joint" type="fixed">

<parent link="base_footprint"/><child link="base_link"/>

<origin xyz="0 0 0.5" rpy="0 0 0"/> </joint>



<link name="base_link">

<visual><geometry><mesh filename="file:///root/colcon_ws/src/hexapod_description/meshes/phantomX/body.stl" scale="0.001 0.001 0.001"/></geometry></visual>

<collision><geometry><box size="0.25 0.15 0.06"/></geometry></collision>

<inertial>

<mass value="3.0"/> <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.1"/>

</inertial>

</link>

<gazebo reference="base_link"><self_collide>false</self_collide></gazebo>



<xacro:macro name="leg" params="side position x y angle">


<joint name="coxa_joint_${side}${position}" type="revolute">

<parent link="base_link"/><child link="coxa_${side}${position}"/><origin xyz="${x} ${y} 0" rpy="0 0 ${angle}"/><axis xyz="0 0 1"/>

<limit lower="-1.57" upper="1.57" effort="30.0" velocity="2.0"/>

<dynamics damping="1.0" friction="0.5"/>

</joint>

<link name="coxa_${side}${position}">

<visual><geometry><mesh filename="file:///root/colcon_ws/src/hexapod_description/meshes/phantomX/coxa.stl" scale="0.001 0.001 0.001"/></geometry></visual>

<collision><geometry><box size="0.05 0.05 0.05"/></geometry></collision>

<inertial><mass value="0.2"/><inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/></inertial>

</link>

<gazebo reference="coxa_${side}${position}"><self_collide>false</self_collide></gazebo>



<joint name="femur_joint_${side}${position}" type="revolute">

<origin xyz="0.029 0 0" rpy="-1.5707 0 0"/><parent link="coxa_${side}${position}"/><child link="femur_${side}${position}"/><axis xyz="0 0 1"/>

<limit lower="-1.57" upper="1.57" effort="30.0" velocity="2.0"/>

<dynamics damping="1.0" friction="0.5"/>

</joint>

<link name="femur_${side}${position}">

<visual><geometry><mesh filename="file:///root/colcon_ws/src/hexapod_description/meshes/phantomX/femur.stl" scale="0.001 0.001 0.001"/></geometry></visual>

<collision><geometry><box size="0.08 0.03 0.03"/></geometry></collision>

<inertial><mass value="0.2"/><inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/></inertial>

</link>

<gazebo reference="femur_${side}${position}"><self_collide>false</self_collide></gazebo>



<joint name="tibia_joint_${side}${position}" type="revolute">

<origin xyz="0.082 0 0" rpy="0 0 0"/><parent link="femur_${side}${position}"/><child link="tibia_${side}${position}"/><axis xyz="0 0 1"/>

<limit lower="-1.57" upper="1.57" effort="30.0" velocity="2.0"/>

<dynamics damping="1.0" friction="0.5"/>

</joint>

<link name="tibia_${side}${position}">

<visual><geometry><mesh filename="file:///root/colcon_ws/src/hexapod_description/meshes/phantomX/tibia.stl" scale="0.001 0.001 0.001"/></geometry></visual>

<collision>

<origin xyz="0.12 0 0" rpy="0 0 0"/> <geometry><sphere radius="0.025"/></geometry> </collision>

<inertial><mass value="0.2"/><inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/></inertial>

</link>

<gazebo reference="tibia_${side}${position}">

<self_collide>false</self_collide>

<mu1>2.0</mu1><mu2>2.0</mu2>

<kp>10000000.0</kp><kd>100.0</kd>

<maxVel>0.01</maxVel> <minDepth>0.005</minDepth> </gazebo>

</xacro:macro>



<xacro:leg side="R" position="F" x="0.124" y="-0.10" angle="-0.785"/>

<xacro:leg side="R" position="M" x="0.0" y="-0.13" angle="-1.57"/>

<xacro:leg side="R" position="R" x="-0.124" y="-0.10" angle="-2.35"/>

<xacro:leg side="L" position="F" x="0.124" y="0.10" angle="0.785"/>

<xacro:leg side="L" position="M" x="0.0" y="0.13" angle="1.57"/>

<xacro:leg side="L" position="R" x="-0.124" y="0.10" angle="2.35"/>



<ros2_control name="GazeboSystem" type="system">

<hardware><plugin>gazebo_ros2_control/GazeboSystem</plugin></hardware>

<xacro:macro name="j" params="n"><joint name="${n}"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint></xacro:macro>
 
<xacro:j n="coxa_joint_RF"/><xacro:j n="femur_joint_RF"/><xacro:j n="tibia_joint_RF"/><xacro:j n="coxa_joint_RM"/><xacro:j n="femur_joint_RM"/><xacro:j n="tibia_joint_RM"/><xacro:j n="coxa_joint_RR"/><xacro:j n="femur_joint_RR"/><xacro:j n="tibia_joint_RR"/><xacro:j n="coxa_joint_LF"/><xacro:j n="femur_joint_LF"/><xacro:j n="tibia_joint_LF"/><xacro:j n="coxa_joint_LM"/><xacro:j n="femur_joint_LM"/><xacro:j n="tibia_joint_LM"/><xacro:j n="coxa_joint_LR"/><xacro:j n="femur_joint_LR"/><xacro:j n="tibia_joint_LR"/>

</ros2_control>



<gazebo><plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so"><parameters>/root/colcon_ws/src/hexapod_gazebo/config/phantomx_control.yaml</parameters></plugin></gazebo>

</robot>